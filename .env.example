# ─── Environment ───────────────────────────────────────────────
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/class_action_os
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ───────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ─── Source APIs ───────────────────────────────────────────────
# PACER credentials (register at https://pacer.uscourts.gov)
PACER_USERNAME=
PACER_PASSWORD=
PACER_CLIENT_CODE=

# CourtListener API (register at https://www.courtlistener.com)
COURTLISTENER_API_TOKEN=

# SEC EDGAR (optional user-agent for API)
SEC_USER_AGENT=ClassActionOS/1.0 (your-email@example.com)

# ─── AI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# ─── Storage ──────────────────────────────────────────────────
STORAGE_DRIVER=local
# S3-compatible settings (for production)
S3_BUCKET=class-action-os-docs
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── Auth ──────────────────────────────────────────────────────
# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Notifications ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@classactionos.dev

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
